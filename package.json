      "types": "./dist/main.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "dist/main.d.ts",
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "@types/resolve": "^1.20.6",
    "sass": "^1.91.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4"
  }
}